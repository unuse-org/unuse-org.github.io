---
const { email = 'contact@ununse.com', social = [] } = Astro.props;
---

<div class="contact-panel max-w-7xl mx-auto px-4 sm:px-6 py-10">
  <div class="contact-inner rounded-lg border p-6 bg-white/90 dark:bg-[#05121a]">
    <h3 class="text-2xl font-semibold mb-2">Contact</h3>
    <p class="mb-4 text-muted">ご連絡は以下まで。</p>
    <div class="flex flex-col sm:flex-row sm:items-center sm:gap-6">
      <a class="btn btn-primary" href={`mailto:${email}`}>メールで問い合わせ</a>
      <div class="socials mt-3 sm:mt-0 flex gap-3 items-center">
        {
          social.length ? (
            social.map((s: { label: string; href: string }) => (
              <a class="underline text-primary" href={s.href} target="_blank" rel="noopener">
                {s.label}
              </a>
            ))
          ) : (
            <>
              <a class="underline text-primary" href="#">
                Twitter
              </a>
              <a class="underline text-primary" href="#">
                Github
              </a>
            </>
          )
        }
      </div>
    </div>
  </div>
</div>

<style>
  .contact-panel {
    color: #0b1830;
  }
  .contact-inner {
    border: 1px solid rgba(11, 93, 112, 0.08);
  }
</style>
