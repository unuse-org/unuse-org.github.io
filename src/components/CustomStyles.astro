---
// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  @import url('https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700;900&family=Chakra+Petch:wght@500;600;700&display=swap');

  :root {
    --aw-font-sans: 'Zen Kaku Gothic New', 'Hiragino Sans', 'Noto Sans JP', sans-serif;
    --aw-font-serif: 'Zen Kaku Gothic New', 'Hiragino Sans', 'Noto Sans JP', sans-serif;
    --aw-font-heading: 'Chakra Petch', 'Zen Kaku Gothic New', sans-serif;

    --aw-color-primary: rgb(255 122 34);
    --aw-color-secondary: rgb(11 134 147);
    --aw-color-accent: rgb(245 66 93);

    --aw-color-text-heading: rgb(10 19 35);
    --aw-color-text-default: rgb(23 34 47);
    --aw-color-text-muted: rgb(23 34 47 / 66%);
    --aw-color-bg-page: rgb(251 254 255);

    --aw-color-bg-page-dark: rgb(4 14 24);

    ::selection {
      background-color: rgb(255 210 182);
    }
  }

  .dark {
    --aw-font-sans: 'Zen Kaku Gothic New', 'Hiragino Sans', 'Noto Sans JP', sans-serif;
    --aw-font-serif: 'Zen Kaku Gothic New', 'Hiragino Sans', 'Noto Sans JP', sans-serif;
    --aw-font-heading: 'Chakra Petch', 'Zen Kaku Gothic New', sans-serif;

    --aw-color-primary: rgb(255 140 49);
    --aw-color-secondary: rgb(41 195 202);
    --aw-color-accent: rgb(255 93 118);

    --aw-color-text-heading: rgb(237 246 255);
    --aw-color-text-default: rgb(216 228 239);
    --aw-color-text-muted: rgb(216 228 239 / 66%);
    --aw-color-bg-page: rgb(4 14 24);

    ::selection {
      background-color: rgb(255 122 34);
      color: rgb(8 14 22);
    }
  }
</style>
