---
import { SITE } from 'astrowind:config';
import logoImage from '~/assets/images/unuse.jpg';
---

<span class="logo-mark" aria-label={SITE?.name}>
  <img src={logoImage.src} width={logoImage.width} height={logoImage.height} alt={`${SITE?.name ?? 'ununse'} logo`} />
</span>

<style>
  .logo-mark {
    display: inline-flex;
    align-items: center;
    width: 112px;
    height: 40px;
    overflow: hidden;
  }

  .logo-mark img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  @media (min-width: 768px) {
    .logo-mark {
      width: 104px;
      height: 38px;
    }
  }
</style>
