---
import Layout from '~/layouts/PageLayout.astro';
import { works } from '~/data/works';

import cubeDePonImage from '~/assets/images/hero-cube.png';
import cinemaImage from '~/assets/images/hero-cinema.png';
import kanpaiImage from '~/assets/images/hero-kanpai.png';
import Contact from '~/components/Contact.astro';

const heroImages = [
  { src: cubeDePonImage, alt: 'キューブでポン' },
  { src: cinemaImage, alt: 'シネマオペレーター' },
  { src: kanpaiImage, alt: '乾杯の音頭は破壊から' },
];
const featuredWorks = works.slice(0, 3);

const metadata = {
  title: 'ununse',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <section class="ununse-hero">
    <div class="ununse-hero__glow ununse-hero__glow-a" aria-hidden="true"></div>
    <div class="ununse-hero__glow ununse-hero__glow-b" aria-hidden="true"></div>
    <div class="ununse-hero__mesh" aria-hidden="true"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-20 lg:py-24 relative">
      <div class="ununse-hero__layout">
        <div>
          <h1>
            ふだん使うものが、<br />
            ゲームになる。
          </h1>
          <p class="ununse-lead">ununseは、日常のモノをあえてゲームのコントローラーに変える同人ゲームサークル。</p>
          <div class="ununse-actions">
            <a href="#concept" class="btn btn-primary">コンセプトを見る</a>
            <a href="/works" class="btn btn-secondary ununse-btn-ghost">作品を見る</a>
          </div>
        </div>
        <div class="ununse-screen" aria-hidden="true">
          {
            heroImages.map((img) => (
              <img
                src={typeof img.src === 'string' ? img.src : img.src.src}
                alt={img.alt}
                class="ununse-screen__image"
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="concept" class="ununse-section max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-20">
    <div class="ununse-headline">
      <p>Concept</p>
      <h2>手に取った瞬間が、<br />ゲームの始まり。</h2>
    </div>
    <div class="ununse-concept-grid">
      <article>
        <h3>予想外から始まる</h3>
        <p>「なぜこれで？」という驚き。その戸惑いが、ゲームへの没入の入口になります。</p>
      </article>
      <article>
        <h3>その場で遊べる</h3>
        <p>難しくなく、だから面白い。展示でも、どこでも。すぐに楽しめる。</p>
      </article>
    </div>
  </section>

  <section class="ununse-section ununse-works max-w-7xl mx-auto px-4 sm:px-6 pb-16 md:pb-20">
    <div class="ununse-headline">
      <p>Featured Works</p>
      <h2>制作したゲーム</h2>
    </div>
    <div class="ununse-works-grid">
      {
        featuredWorks.map((work) => (
          <a href={`/works/${work.slug}`} class="ununse-work-card">
            <img src={work.image.src} alt={work.title} loading="lazy" />
            <div>
              <h3>{work.title}</h3>
              <p>{work.description}</p>
            </div>
          </a>
        ))
      }
    </div>
    <div class="pt-4">
      <a href="/works" class="btn btn-secondary">すべての作品を見る</a>
    </div>
  </section>

  <section id="about" class="ununse-section ununse-about max-w-7xl mx-auto px-4 sm:px-6 pb-20">
    <div class="ununse-about__panel">
      <h2>About ununse</h2>
      <p>ununseは大学発の同人ゲームサークルです。日常のモノをあえてコントローラーに変えたゲームを制作しています。</p>
      <ul>
        <li><strong>設立:</strong> 2020年</li>
        <li><strong>メンバー:</strong> 6名</li>
      </ul>
    </div>
  </section>

  <!-- Contact -->
  <Contact
    email="ununse.org@gmail.com"
    social={[
      { label: 'Twitter（X）', href: 'https://x.com/UNUSE_AIT' },
      { label: 'Github', href: 'https://github.com/unuse-org' },
    ]}
  />
</Layout>

<style>
  .ununse-hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 10% 20%, rgba(255, 128, 36, 0.2), transparent 35%),
      radial-gradient(circle at 80% 15%, rgba(34, 191, 188, 0.24), transparent 42%),
      linear-gradient(180deg, #f6fbff 0%, #eef6ff 42%, #f8fbff 100%);
  }

  .ununse-hero__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  .ununse-hero h1 {
    font-size: clamp(2.1rem, 4.7vw, 4.1rem);
    line-height: 1.06;
    letter-spacing: -0.03em;
    margin-top: 0.8rem;
    margin-bottom: 1rem;
    color: #0b1830;
  }

  .ununse-lead {
    max-width: 620px;
    line-height: 1.95;
    color: #2a3f56;
    font-size: 1.03rem;
  }

  .ununse-actions {
    margin-top: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .ununse-btn-ghost {
    border-color: #0d6f7b;
    color: #0d6f7b;
    background: rgba(255, 255, 255, 0.68);
  }

  .ununse-btn-ghost:hover {
    background: #dff7f5;
    border-color: #0a5560;
    color: #0a5560;
  }

  .ununse-screen {
    position: absolute;
    min-height: 360px;
    border-radius: 1.2rem;
    overflow: hidden;
    border: 1px solid rgba(13, 111, 123, 0.24);
    box-shadow: 0 20px 40px rgba(4, 18, 33, 0.16);
    background: #0a1422;
  }

  .ununse-screen__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.35rem;
    opacity: 0;
    animation: crossfade 10s ease-in-out infinite;
  }

  .ununse-screen__image:nth-child(1) {
    animation-delay: 0s;
  }

  .ununse-screen__image:nth-child(2) {
    animation-delay: 5s;
  }

  .ununse-hero__mesh {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(7, 108, 122, 0.16) 1px, transparent 1px),
      linear-gradient(90deg, rgba(7, 108, 122, 0.16) 1px, transparent 1px);
    background-size: 24px 24px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.82), transparent 75%);
    opacity: 0.5;
    pointer-events: none;
  }

  .ununse-hero__glow {
    position: absolute;
    border-radius: 9999px;
    filter: blur(4px);
    pointer-events: none;
  }

  .ununse-hero__glow-a {
    width: 40vw;
    height: 40vw;
    min-width: 260px;
    min-height: 260px;
    top: -10%;
    left: -10%;
    background: radial-gradient(circle at center, rgba(255, 122, 34, 0.32) 0%, rgba(255, 122, 34, 0) 68%);
  }

  .ununse-hero__glow-b {
    width: 36vw;
    height: 36vw;
    min-width: 220px;
    min-height: 220px;
    top: -6%;
    right: -8%;
    background: radial-gradient(circle at center, rgba(23, 195, 190, 0.34) 0%, rgba(23, 195, 190, 0) 70%);
  }

  .ununse-section {
    position: relative;
  }

  .ununse-headline p {
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #0b808e;
    font-weight: 800;
  }

  .ununse-headline h2 {
    margin-top: 0.5rem;
    font-size: clamp(1.7rem, 3.4vw, 2.8rem);
    line-height: 1.18;
    letter-spacing: -0.02em;
    color: #0f1f36;
  }

  .ununse-concept-grid {
    margin-top: 1.4rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  .ununse-concept-grid article {
    border-radius: 1rem;
    border: 1px solid rgba(12, 124, 136, 0.22);
    background: linear-gradient(135deg, rgba(255, 255, 255, 1) 0%, rgba(240, 251, 251, 1) 100%);
    padding: 1.2rem;
    box-shadow: 0 12px 24px rgba(4, 24, 40, 0.08);
  }

  .ununse-concept-grid h3 {
    font-size: 1.08rem;
    margin-bottom: 0.45rem;
  }

  .ununse-concept-grid p {
    line-height: 1.8;
    color: #395067;
  }

  .ununse-works-grid {
    margin-top: 1.3rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .ununse-work-card {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 0.85rem;
    align-items: center;
    border-radius: 1rem;
    padding: 0.8rem;
    border: 1px solid rgba(11, 93, 112, 0.2);
    background: #ffffff;
    transition:
      transform 220ms ease,
      box-shadow 220ms ease;
  }

  .ununse-work-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 28px rgba(7, 30, 48, 0.12);
  }

  .ununse-work-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 0.75rem;
    border: 1px solid rgba(9, 23, 43, 0.1);
  }

  .ununse-work-card h3 {
    font-size: 1.05rem;
    color: #091c33;
    margin-bottom: 0.2rem;
  }

  .ununse-work-card p {
    color: #415872;
    font-size: 0.93rem;
    line-height: 1.75;
    margin: 0;
  }

  .ununse-about__panel {
    border-radius: 1rem;
    border: 1px solid rgba(8, 81, 106, 0.24);
    background: linear-gradient(120deg, rgba(11, 28, 50, 1) 0%, rgba(9, 50, 74, 1) 100%);
    color: #eaf7ff;
    padding: 1.35rem;
    box-shadow: 0 18px 34px rgba(3, 14, 30, 0.22);
  }

  .ununse-about__panel h2 {
    font-size: clamp(1.45rem, 2.5vw, 2rem);
    margin-bottom: 0.65rem;
  }

  .ununse-about__panel p {
    line-height: 1.88;
    color: rgba(236, 246, 255, 0.88);
  }

  .ununse-about__panel ul {
    margin-top: 0.8rem;
    display: grid;
    gap: 0.25rem;
    color: rgba(236, 246, 255, 0.95);
  }

  @media (min-width: 900px) {
    .ununse-hero__layout {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: 2.1rem;
    }

    .ununse-screen {
      position: relative;
      min-height: 430px;
    }

    .ununse-concept-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.15rem;
    }

    .ununse-works-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .ununse-work-card {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }

  @media (max-width: 899px) {
    .ununse-screen {
      position: relative;
    }
  }

  @keyframes crossfade {
    0% {
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    42% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }
</style>
