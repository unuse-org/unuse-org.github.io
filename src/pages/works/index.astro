---
import Layout from '~/layouts/PageLayout.astro';
import { works } from '~/data/works';

const metadata = {
  title: 'Works',
};
---

<Layout metadata={metadata}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <h1 class="text-3xl font-bold mb-4">Works</h1>
    <p class="text-muted mb-8">ununseが制作したゲーム作品です。日用品をコントローラーに変える実験の成果。</p>

    <div class="grid gap-6 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
      {
        works.map((work) => (
          <a
            href={`/works/${work.slug}`}
            class="work-card rounded-lg border overflow-hidden bg-white transition hover:shadow-lg"
          >
            <div class="aspect-video overflow-hidden">
              <img
                src={work.image.src}
                alt={work.title}
                class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="p-5">
              <div class="flex flex-wrap gap-2 mb-3">
                {work.tags.map((tag) => (
                  <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-[rgb(208,250,247)] text-[#0d6f7b] border border-[rgba(13,111,123,0.24)]">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="text-lg font-bold mb-2 text-[#0f1f36] group-hover:text-primary transition-colors">
                {work.title}
              </h2>
              <p class="text-[#2a3f56] text-sm">{work.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .work-card {
    border: 1px solid rgba(11, 93, 112, 0.16);
    box-shadow: 0 8px 18px rgba(5, 18, 30, 0.04);
  }
</style>
